
<br>
    <%= form_for([current_user, current_user.posts.build]) do |f| %>  
    <%= f.text_field :title, placeholder: "Заглавие" %><br>
    <%= f.text_area :text, placeholder: "Текст поста", :size => '70x2' %><br>
    <%= f.submit "Добавить пост", :class => 'btn btn-large btn-primary' %> 
<% end %>       
<br>
<br>

<table class="table table-striped">
  <tbody>
  <% @posts.each do |post| %> 
    <tr><td>
      <p><strong><%= link_to post.title, post %></strong></p>
      <p><%= with_new_lines post.text %></p>
      <p><small>Написал <%= link_to post.user.name, post.user %>,
        <%= post.created_at.strftime("%d.%m.%Y %H:%M") %>, 
        <%= post.comments.count %> комментариев. 
      <% if current_user.admin %>    
        <%= link_to "[ Удалить ]", post, :method => :delete, data: { confirm: "Вы серьезно?" }  %> 
      <% end %>
      </small></p>
    </td></tr>
  <% end %>
 </tbody>
</table>
<% if @posts.size == 0 %>
  <em>Постов почему-то нет.</em>
<% end %>
