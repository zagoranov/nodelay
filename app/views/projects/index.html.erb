<h3>Проекты</h3>

<br>

<% if @projects.size > 0 %>
<table class="table table-striped">
  <tbody>
  <% @projects.each do |proj| %> 
    <tr>
      <td><%= link_to proj.name, edit_project_path(proj) %></td>
      <td><%= proj.description %></td>
      <td><%= proj.tip %></td>      
      <td><%= proj.created_at.strftime("%d.%m.%Y") %></td>
    </tr>
  <% end %>
 </tbody>
</table>
<% else %>  
  <em> Список пуст. </em>
<% end %>


<div id="new_project">
  <%= render 'projects/shortform' %>
</div>
